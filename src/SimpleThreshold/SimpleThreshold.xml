<?xml version="1.0" encoding="utf-8"?>
<executable>
    <category>MIATT.HW04.cavriley</category>
    <title>Simple Thresholding Filter</title>
    <description>
        Performs simple thresholding on an input image and produces the output image.
    </description>
    <version>97.0</version>
    <documentation-url></documentation-url>
    <license></license>
    <contributor>Cavan Riley</contributor>

    <parameters>
        <label>
            Threshold Parameters
        </label>
        <description>
            Parameters for performing a simple thresholding
        </description>

        <integer>
            <name>numberOfIterations</name>
            <longflag>iterations</longflag>
            <description>Number of iterations</description>
            <label>Iterations</label>
            <default>1</default>
            <constraints>
                <minimum>1</minimum>
                <maximum>30</maximum>
                <step>1</step>
            </constraints>
        </integer>

        <integer>
            <name>lowThreshold</name>
            <longflag>lowThreshold</longflag>
            <description>Low Threshold for Filter</description>
            <label>LowThreshold</label>
            <default>1</default>
            <constraints>
                <minimum>-10000</minimum>
                <maximum>10000</maximum>
                <step>10</step>
            </constraints>
        </integer>

        <integer>
            <name>highThreshold</name>
            <longflag>highThreshold</longflag>
            <description>High Threshold for Filter</description>
            <label>HighThreshold</label>
            <default>1</default>
            <constraints>
                <minimum>-10000</minimum>
                <maximum>10000</maximum>
                <step>10</step>
            </constraints>
        </integer>

        <integer>
            <name>outsideValue</name>
            <longflag>outsideValue</longflag>
            <description>Value to set outside of threshold</description>
            <label>OutsideValue</label>
            <default>1</default>
            <constraints>
                <minimum>-10000</minimum>
                <maximum>10000</maximum>
                <step>10</step>
            </constraints>
        </integer>

        <integer>
            <name>insideValue</name>
            <longflag>insideValue</longflag>
            <description>Value to set inside of threshold</description>
            <label>InsideValue</label>
            <default>1</default>
            <constraints>
                <minimum>-10000</minimum>
                <maximum>10000</maximum>
                <step>10</step>
            </constraints>
        </integer>

    </parameters>

    <parameters>
        <label>IO</label>
        <description>Input/output parameters</description>
        <image>
            <name>input</name>
            <longflag>inputVolume</longflag>
            <label>Input Volume</label>
            <channel>input</channel>
            <description>Input volume to be filtered</description>
        </image>
        <image>
            <name>output</name>
            <longflag>outputVolume</longflag>
            <label>Output Volume</label>
            <channel>output</channel>
            <description>Output filtered</description>
        </image>
    </parameters>

</executable>
